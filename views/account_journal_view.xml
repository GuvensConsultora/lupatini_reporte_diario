<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Agrega el campo "Tipo en Reporte Diario" al formulario del diario.
        Por qué inherit_id account.view_account_journal_form: es la vista
        principal del diario contable en Odoo 17.
    -->
    <record id="view_account_journal_lupatini_reporte" model="ir.ui.view">
        <field name="name">account.journal.lupatini.reporte.diario</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="lupatini_ingreso_tipo"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_journal_lupatini_list" model="ir.ui.view">
        <field name="name">account.journal.lupatini.reporte.diario.list</field>
        <field name="model">account.journal</field>
        <field name="arch" type="xml">
            <tree string="Diarios - Reporte Diario" editable="top">
                <field name="name"/>
                <field name="type"/>
                <field name="code"/>
                <field name="lupatini_ingreso_tipo"/>
            </tree>
        </field>
    </record>

    <record id="action_account_journal_lupatini_config" model="ir.actions.act_window">
        <field name="name">Configurar Tipos de Ingreso</field>
        <field name="res_model">account.journal</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_account_journal_lupatini_list"/>
    </record>

    <menuitem
        id="menu_account_journal_lupatini_config"
        name="Configurar Tipos de Ingreso"
        parent="account_accountant.menu_accounting"
        action="action_account_journal_lupatini_config"
        sequence="91"/>

</odoo>
