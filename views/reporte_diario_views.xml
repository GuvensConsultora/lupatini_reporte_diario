<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================= -->
    <!-- Wizard: formulario                                                 -->
    <!-- ================================================================= -->
    <record id="view_reporte_diario_wizard_form" model="ir.ui.view">
        <field name="name">lupatini.reporte.diario.wizard.form</field>
        <field name="model">lupatini.reporte.diario.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte Diario de Ingresos">
                <group>
                    <field name="date"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <footer>
                    <button name="action_export_excel"
                            string="Exportar Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ================================================================= -->
    <!-- Acción que abre el wizard                                          -->
    <!-- ================================================================= -->
    <record id="action_reporte_diario_wizard" model="ir.actions.act_window">
        <field name="name">Reporte Diario de Ingresos</field>
        <field name="res_model">lupatini.reporte.diario.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_reporte_diario_ingresos"
        name="Reporte Diario de Ingresos"
        parent="lupatini_reporte_diario.menu_lupatini_reportes"
        action="action_reporte_diario_wizard"
        sequence="10"/>

</odoo>
